generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum Role {
  citizen
  admin
}

enum Category {
  illegal_dump
  air_pollution
  water_pollution
  broken_container
  other
}

enum Status {
  submitted
  in_progress
  resolved
  archived
}

model User {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String          @unique @db.VarChar(255)
  password_hash  String          @db.VarChar(255)
  display_name   String          @db.VarChar(100)
  role           Role            @default(citizen)
  points         Int             @default(0)
  level          Int             @default(1) @db.SmallInt
  created_at     DateTime        @default(now()) @db.Timestamptz

  reports        Report[]
  votes          Vote[]
  status_changes StatusHistory[]

  @@map("users")
}

model Report {
  id             String                                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String                                 @db.Uuid
  category       Category
  title          String                                 @db.VarChar(200)
  description    String?                                @db.Text
  location       Unsupported("geography(Point, 4326)")
  image_url      String                                 @db.Text
  status         Status                                 @default(submitted)
  heat_score     Float                                  @default(0)
  vote_count     Int                                    @default(0)
  created_at     DateTime                               @default(now()) @db.Timestamptz
  updated_at     DateTime                               @updatedAt @db.Timestamptz
  resolved_at    DateTime?                              @db.Timestamptz

  user           User            @relation(fields: [user_id], references: [id])
  votes          Vote[]
  status_history StatusHistory[]

  @@map("reports")
}

model Vote {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  report_id  String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz

  user   User   @relation(fields: [user_id], references: [id])
  report Report @relation(fields: [report_id], references: [id])

  @@unique([user_id, report_id])
  @@map("votes")
}

model StatusHistory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  report_id  String   @db.Uuid
  changed_by String   @db.Uuid
  old_status Status
  new_status Status
  comment    String?  @db.Text
  changed_at DateTime @default(now()) @db.Timestamptz

  report Report @relation(fields: [report_id], references: [id])
  admin  User   @relation(fields: [changed_by], references: [id])

  @@map("status_history")
}
