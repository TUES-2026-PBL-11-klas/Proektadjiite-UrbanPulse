apiVersion: v1
kind: Secret
metadata:
  name: urbanpulse-secrets
  namespace: urbanpulse
  labels:
    app.kubernetes.io/part-of: urbanpulse
  annotations:
    # TEMPLATE ONLY — never commit real values to this file.
    # Real secrets are injected by Terraform via the kubernetes_secret resource in terraform/main.tf.
    # Local dev: copy terraform/terraform.tfvars.example → terraform/terraform.tfvars and run make up.
    # CI/CD: GitHub Secrets (JWT_SECRET, DB_PASSWORD, etc.) are written to k8s via kubectl in the CD workflow.
type: Opaque
stringData:
  DATABASE_URL: "REPLACE_VIA_TERRAFORM"  # pragma: allowlist secret
  JWT_SECRET: "REPLACE_VIA_TERRAFORM"    # pragma: allowlist secret
  DB_PASSWORD: "REPLACE_VIA_TERRAFORM"   # pragma: allowlist secret
  SMTP_USER: "REPLACE_VIA_TERRAFORM"     # pragma: allowlist secret
  SMTP_PASS: "REPLACE_VIA_TERRAFORM"     # pragma: allowlist secret
